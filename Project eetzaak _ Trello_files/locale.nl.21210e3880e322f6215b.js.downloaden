}","templates.search_instant_results.show-more-boards-ellipsis":"Laat meer borden zien...","templates.search_instant_results.refine-your-search-with-operators-like-at-member-label-is-archived-and-has-attachments":"Verfijn je zoekopdracht met opties zoals @lid, #label, {is}:{archived}, en {has}:{attachments}.","templates.search_instant_results.cards":"Kaarten","templates.search_instant_results.show-more-members-ellipsis":"Meer leden weergeven...","templates.search_instant_results.description-checklist-comment-and-name":"{description}:, {checklist}:, {comment}:, en {name}:","templates.search_instant_results.is-starred":"{is}:{starred}","templates.search_instant_results.list-name":"{list}:{name}","templates.search_instant_results.saved-searches":"Bewaarde zoekopdrachten","templates.search_instant_results.organizations":"Workspaces","templates.search_instant_results.returns-labeled-cards-trello-will-suggest-labels-for-you-if-you-start-typing-and-the-label-you-are-looking-for-label-also-works":"Geeft gelabelde kaarten weer. <strong>{label}:</strong> werkt ook.","templates.search_instant_results.loading-ellipsis":"Bezig met laden...","templates.search_instant_results.label":"#label","templates.search_instant_results.save":"Bewaar","templates.search_instant_results.save-this-search":"Bewaar deze zoekopdracht","templates.search_instant_results.is-open-and-is-archived":"{is}:{open} en {is}:{archived}","templates.search_instant_results.looking-for-help-using-trello":"Hulp nodig bij het gebruiken van Trello?","templates.search_instant_results.search-our-help-site-for":'Bezoek onze hulppagina voor <span class="search-help-query js-query"></span>',"templates.search_instant_results.visit-our-help-site-or-read-the-guide":'Bezoek <a href="http://help.trello.com/?source=trello-search" target="help">onze hulppagina</a> of raadpleeg <a href="/guide?source=trello-search" target="guide">&quot;Beginnen met Trello&quot;</a>',"templates.search_instant_results.sort-created":"{sort}:{created}","templates.search_instant_results.sorts-cards-by-date-created-sort-edited-and-sort-due-also-work-as-expected":"Sorteert kaarten op aanmaakdatum. <strong>{sort}:{edited}</strong> en <strong>{sort}:{due}</strong> werken ook naar verwachting.","templates.search_instant_results.recent-boards":"Recente borden","templates.search_instant_results.starred-boards":"Borden met ster","templates.search_instant_results.back":"Vorige","templates.search_instant_results.jump-to":"Doorgaan naar...","templates.search_instant_results.search-ellipsis":"Zoeken...","templates.search_instant_results.search":"Zoeken","templates.search_instant_results.open-search":"Zoekfunctie openen","templates.search_instant_results.upgrade":"Upgraden","templates.search_instant_results.start-free-trial":"Aan de slag met de gratis proefversie","templates.search_instant_results.help-us-improve-your-search-results":"Help ons je zoekresultaten te verbeteren.","templates.search_page.adding-sorting-and-filtering":"Als je sortering en filters toevoegt, worden alleen de kaartresultaten weergegeven.","templates.search_page.any":"Alle","templates.search_page.anytime":"Altijd","templates.search_page.archived":"Gearchiveerd","templates.search_page.board":"Bord","templates.search_page.boards":"Borden","templates.search_page.board-closed-tooltip":"Dit bord is gesloten. Om dit bord te markeren met een ster moet je het eerst opnieuw openen.","templates.search_page.by-relevancy":"Op relevantie","templates.search_page.by-last-updated":"Op datum 'Laatst bijgewerkt'","templates.search_page.card-descriptions":"Kaartomschrijvingen","templates.search_page.cards":"Kaarten","templates.search_page.clear-all-filters":"Alle filters wissen","templates.search_page.click-to-star":"Klik om dit bord te markeren met een ster.","templates.search_page.click-to-unstar":"Klik om de stermarking van dit bord te verwijderen.","templates.search_page.closed":"Gesloten","templates.search_page.description":"Omschrijving","templates.search_page.enter-your-search-keyword":"Voer hier je zoekwoord in","templates.search_page.error":"Fout","templates.search_page.error-flag-description":"Er is iets misgegaan en we weten niet precies wat. Probeer de pagina te herladen.","templates.search_page.error-flag-unable-to-delete-saved-search":"Kan de opgeslagen zoekopdracht niet verwijderen","templates.search_page.error-flag-unable-to-load-more-cards":"Kan niet meer kaarten laden","templates.search_page.error-flag-unable-to-save-your-search":"Kan je zoekopdracht niet opslaan","templates.search_page.failure-to-load-recent-boards-or-fetch-results":"Er is iets misgegaan en we weten niet precies wat.","templates.search_page.filter-cards-by-board":"Kaarten filteren op bord","templates.search_page.filter-by-card":"Filteren op kaart","templates.search_page.filter-cards-by-last-updated":"Kaarten filteren op laatst bijgewerkt","templates.search_page.find-a-board":"Een bord zoeken","templates.search_page.get-more-specific-with-your-search":"Maak je zoekopdracht specifieker met opties zoals @lid, #label, is:archived en has:attachments.","templates.search_page.include-card-descriptions-in-search":"Kaartomschrijvingen opnemen in zoekopdracht","templates.search_page.do-not-show-closed-boards-and-archived-cards":"Geen gesloten borden en gearchiveerde kaarten weergeven","templates.search_page.last-24-hours":"Afgelopen 24 uur","templates.search_page.last-month":"Vorige maand","templates.search_page.last-week":"Vorige week","templates.search_page.last-year":"Vorig jaar","templates.search_page.learn-more":"Lees meer","templates.search_page.list":"Lijst","templates.search_page.loading...":"Laden...","templates.search_page.only-include-cards-on-starred-boards":"Alleen kaarten van een bord met ster.","templates.search_page.only-include-results-from-starred-boards":"Alleen resultaten van Borden met ster opnemen","templates.search_page.closed-boards-and-archived-cards":"Gesloten borden en gearchiveerde kaarten","templates.search_page.private-workspace":"Priv\xe9 Workspace","templates.search_page.recent-boards":"Recente borden","templates.search_page.reload-page":"Pagina herladen","templates.search_page.returns-cards-assigned-to-a-member-typing-membername-also-works":"Toont kaarten die zijn toegewezen aan een lid. <strong>{member_membername}</strong> typen werkt ook. <strong>{me}</strong> toont alleen de kaarten waar je lid van bent.","templates.search_page.returns-cards-created-in-the-last-24-hours-created-week-and-created-month-also-work-as-expected-you-can-search-for-a-specific-day-range-for-example-adding-created-14-to-the-search-will-include-cards-created-in-the-last-14-days":"Toont kaarten die in de laatste 24 uur zijn aangemaakt. <strong>{created}:{week}</strong> en <strong>{created}:{month}</strong> werken ook zoals verwacht. Je kan ook op een specifieke periode zoeken. Als je bijvoorbeeld <strong>{created}:14</strong> toevoegt worden alle kaarten die de laatste 14 dagen zijn gemaakt getoond.","templates.search_page.returns-cards-due-within-24-hours-due-week-due-month-and-due-overdue-also-work-as-expected-you-can-search-for-a-specific-day-range-for-example-adding-due-14-to-search-will-include-cards-due-in-the-next-14-days":"Toon kaarten die binnen 24 uur vervallen. <strong>{due}:{week}</strong>, <strong>{due}:{month}</strong> en <strong>{due}:{overdue}</strong> werken ook als verwacht. Je kan ook op een specifieke periode zoeken. Als je bijvoorbeeld <strong>{due}:14</strong> toevoegt aan de zoekopdracht worden alle kaarten die binnen 14 dagen vervallen getoond.","templates.search_page.returns-cards-edited-in-the-last-24-hours-edited-week-and-edited-month-also-work-as-expected-you-can-search-for-a-specific-day-range-for-example-adding-edited-21-to-the-search-will-include-cards-edited-in-the-last-21-days":"Toon kaarten die in de laatste 24 uur zijn bijgewerkt. <strong>{edited}:{week}</strong> en <strong>{edited}:{month}</strong> werken ook als verwacht. Je kan ook op een specifieke periode zoeken. Als je bijvoorbeeld <strong>{edited}:21</strong> toevoegt aan de zoekopdracht, worden kaarten die de laatste 21 dagen zijn bijgewerkt getoond.","templates.search_page.returns-cards-matching-the-text-of-card-descriptions-checklists-comments-or-names-for-example-comment-fix-it-will-return-cards-with-fix-it-in-a-comment":'Toont kaarten die de gezochte tekst in de kaartbeschrijving, checklists, opmerkingen of naam bevatten. Bijvoorbeeld, {comment}:"FIX DIT" toont alle kaarten met “FIX DIT” in een opmerking.',"templates.search_page.returns-cards-that-are-open":"Toont kaarten die openstaan.","templates.search_page.returns-cards-that-are-marked-complete":"Retourneert kaarten die als compleet zijn gemarkeerd.","templates.search_page.returns-cards-that-arent-marked-complete":"Retourneert kaarten die niet als compleet zijn gemarkeerd.","templates.search_page.returns-cards-with-attachments-has-description-has-cover-has-members-and-has-stickers-also-work-as-you-would-expect":"Toon kaarten met bijlagen. <strong>{has}:{description}</strong>, <strong>{has}:{cover}</strong>, <strong>{has}:{members}</strong>, en <strong>{has}:{stickers}</strong> werken ook zoals je zou verwachten.","templates.search_page.returns-cards-from-a-specific-board-board-keywords-returns-cards-on-boards-with-the-keyword-in-the-board-name":"<strong>{board_boardid}</strong> toont kaarten van een specifiek bord. <strong>{board_keyword}</strong> toont kaarten op borden, waarvan het trefwoord in de bordnaam staat, bijvoorbeeld {board_example}:Trello toont kaarten van borden met 'Trello' in de bordnaam.","templates.search_page.returns-cards-within-the-list-named-name-or-whatever-you-type-besides-name":"Toont kaarten binnen de lijst met de naam “naam”. Of wat je typt naast “naam”.","templates.search_page.returns-cards-with-a-specific-label-labelname-and-labelcolor-also-work":"Toont kaarten met een specifiek label. <strong>{label_labelname} en {label_labelcolor}</strong> werkt ook.","templates.search_page.saved":"Opgeslagen!","templates.search_page.save-this-search":"Bewaar deze zoekopdracht","templates.search_page.save-search-confirm":"Begrepen","templates.search_page.saved-searches":"Bewaarde zoekopdrachten","templates.search_page.search-operators":"Commando's zoeken","templates.search_page.search-operators-refine-your-search-to-help-you-find-specific-cards-and-create-highly-tailored-lists":"Zoekcommando's verfijnen de zoekopdracht en helpen je specifieke kaarten te vinden en zeer afgestemde lijsten te maken. Zo zoek je bijvoorbeeld naar kaarten die zijn toegewezen aan een specifiek lid door ''{has_membername}' te typen.","templates.search_page.members":"Leden","templates.search_page.search":"Zoeken","templates.search_page.search-placeholder":"Zoeken...","templates.search_page.show-more":"Meer weergeven","templates.search_page.sorts-cards-by-date-created-sort-edited-and-sort-due-also-work-as-expected":"Sorteert kaarten op aanmaakdatum. <strong>{sort}:{edited}</strong> en <strong>{sort}:{due}</strong> werken ook naar verwachting.","templates.search_page.sort-card-results":"Kaartresultaten sorteren","templates.search_page.starred":"Met ster","templates.search_page.starred-boards":"Borden met ster","templates.search_page.this-board-is-closed":"Dit bord is gesloten","templates.search_page.this-card-is-archived":"Deze kaart is gearchiveerd","templates.search_page.this-is-a-saved-search":"Dit is een bewaarde zoekopdracht","templates.search_page.this-search-has-been-saved":"Deze zoekopdracht is bewaard.","templates.search_page.Try-reloading-the-page":"Probeer de pagina te herladen.","templates.search_page.updated-time-ago":"{timeAgo} bijgewerkt","templates.search_page.we-couldnt-find-anything-matching-that-search":"We hebben geen items kunnen vinden die overeenkomen met deze zoekopdracht. Probeer het opnieuw met een ander trefwoord.","templates.search_page.workspace":"Workspace","templates.search_page.workspaces":"Workspaces","templates.search_results_card.in-listname-archived-on-boardna